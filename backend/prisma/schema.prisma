generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  displayName String?
  avatar      String? @db.NVarChar(Max)
  coverImage  String? @db.NVarChar(Max)
  dob         DateTime?
  role        String     @default("USER")

  accountType String     @default("PERSONAL") 
  petLimit    Int        @default(5)

  posts       Post[]    
  reactions   Reaction[]
  comments    Comment[]

  pets        Pet[]      @relation("PetOwner")
  coOwnedPets Pet[]      @relation("PetCoOwner")
  adoptions   Pet[]      @relation("ShelterHistory")

  tagBlocks   TagBlock[] @relation("Blocker")
  blockedBy   TagBlock[] @relation("Blocked")

  friendships1 Friendship[] @relation("User1")
  friendships2 Friendship[] @relation("User2")

  notifications Notification[]

  invitesSent     CoOwnerInvitation[] @relation("Inviter")
  invitesReceived CoOwnerInvitation[] @relation("Invitee")

  deletionRequests PetDeletionRequest[]
}

model TagBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int      
  blockedId Int      
  createdAt DateTime @default(now())

  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([blockerId, blockedId])
}

model Pet {
  id                   Int       @id @default(autoincrement())
  
  name                 String?
  avatar               String? @db.NVarChar(Max)
  species              String?
  breed                String?
  age                  Int?
  healthStatus         String?

  ownerId              Int
  coOwnerId            Int?
  shelterId            Int?

  isAdopted            Boolean   @default(false) 
  deletedAt            DateTime?
  isPermanentlyDeleted Boolean   @default(false) 
  requireTagApproval   Boolean   @default(true)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  owner                User      @relation("PetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  coOwner              User?     @relation("PetCoOwner", fields: [coOwnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shelter              User?     @relation("ShelterHistory", fields: [shelterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  postTags             PostTag[] 
  coOwnerInvites       CoOwnerInvitation[]
  deletionRequests     PetDeletionRequest[]
}

model Post {
  id               Int        @id @default(autoincrement())
  content          String? @db.NVarChar(Max)
  image            String? @db.NVarChar(Max)
  authorId         Int
  createdAt        DateTime   @default(now())
  
  // Lost Pet fields
  isLostPet        Boolean    @default(false)
  lastSeenLocation String?
  coordinates      String?
  lostDate         DateTime?
  reward           String?

  author           User       @relation(fields: [authorId], references: [id], onUpdate: NoAction)
  comments         Comment[]
  reactions        Reaction[]
  
  tags             PostTag[]  
}

model PostTag {
  id        Int      @id @default(autoincrement())
  postId    Int
  petId     Int
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([postId, petId])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  type      String
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([userId, postId])
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  userId    Int
  postId    Int
  parentId  Int?
  createdAt DateTime  @default(now())
  parent    Comment?  @relation("NestedComments", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Comment[] @relation("NestedComments")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model CoOwnerInvitation {
  id        Int      @id @default(autoincrement())
  petId     Int
  inviterId Int
  inviteeId Int
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  inviter   User     @relation("Inviter", fields: [inviterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invitee   User     @relation("Invitee", fields: [inviteeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PetDeletionRequest {
  id          Int      @id @default(autoincrement())
  petId       Int
  coOwnerId   Int
  status      String   @default("PENDING") 
  requestedAt DateTime @default(now())

  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  coOwner     User     @relation(fields: [coOwnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Friendship {
  id        Int      @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())

  user1     User     @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("User2", fields: [user2Id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user1Id, user2Id])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   
  message     String
  isRead      Boolean  @default(false)
  referenceId Int?     
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}